<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseWeapon">
    <defName>Rimlight_Shardblade</defName>
    <label>shardblade</label>
    <description>A sword of unreplicable power and orgin. Despite their size, they are surprisingly light to carry. Worth more than some kindgons, few in the world possess these blades, which can be summoned and dismissed from thin air at the will of their wielder after a bonding process. The only way to break this bond is either via the owner of the blade voluntarily giving it up, or through killing the shardbearer. This is unlikely though as a single person wielding one of these blades, when paired with the appropriate plate, can singlehandedly fight entire armies, leaving an unnerving sight of burnt out eyes in their wake.</description>
    <possessionCount>1</possessionCount>
    <smeltable>false</smeltable>
    <graphicData>
      <texPath>RimlightArchive/Rimlight_Oathbringer</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <techLevel>Medieval</techLevel>
    <weaponTags>
      <li>MedievalMeleeAdvanced</li>
      <li>Shardblade</li>
    </weaponTags>
    <thingSetMakerTags><li>RewardStandardQualitySuper</li></thingSetMakerTags>
    <statBases>
      <MarketValue>10000</MarketValue>
      <Mass>2</Mass>
    </statBases>
    <relicChance>3</relicChance>
    <equippedAngleOffset>-65</equippedAngleOffset>
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>1.6</cooldownTime>
      </li>
      <li>
        <label>point</label>
        <capacities>
          <li>Rimlight_ToolCapacity_ShardbladeCut</li>
        </capacities>
        <power>30</power>
        <cooldownTime>1.5</cooldownTime>
        <armorPenetration>0.95</armorPenetration>
      </li>
      <li>
        <label>edge</label>
        <capacities>
          <li>Rimlight_ToolCapacity_ShardbladeCut</li>
        </capacities>
        <power>30</power>
        <cooldownTime>2</cooldownTime>
        <armorPenetration>0.95</armorPenetration>
      </li>
    </tools>
  </ThingDef>

</Defs>