<?xml version="1.0" encoding="utf-8" ?>

<Defs>

    <WeatherDef>
        <defName>Highstorm</defName>
        <label>highstorm</label>
        <isBad>false</isBad> <!--If it was usable for forced weather events it'd be unbalanced-->
        <description>A fierce weather system that traverses the whole world east to west routinely. Any settlements or wildlife not adapted to this extreme weather will face its wrath.</description>
        <temperatureRange>-999~999</temperatureRange>
        <accuracyMultiplier>0.2</accuracyMultiplier>
        <moveSpeedMultiplier>0.3</moveSpeedMultiplier>
        <preventSkygaze>true</preventSkygaze>
        <preventsShuttleLaunch>true</preventsShuttleLaunch>
        <favorability>VeryBad</favorability>
        <perceivePriority>2.5</perceivePriority> <!--Should happen semi-routinely, not yet implemented-->
        <windSpeedFactor>2</windSpeedFactor>
        <windSpeedOffset>1.5</windSpeedOffset>
        <weatherThought>OutInHighstorm</weatherThought>
        <rainRate>1</rainRate>
        <letterDef>ThreatSmall</letterDef>
        <letterLabel>Highstorm</letterLabel>
        <letterText>A Highstorm is imminent! Seek shelter immediately, or face the wrath of the Stormfather.</letterText>
        <ambientSounds>
            <li>Ambient_TorrentialRain</li>
            <li>Ambient_Wind_Storm</li>
        </ambientSounds>
        <durationRange>2500~7500</durationRange>
        <overlayClasses>
            <li>WeatherOverlay_TorrentialRain</li>
        </overlayClasses>
        <eventMakers>
            <li>
                <averageInterval>600</averageInterval>
                <eventClass>WeatherEvent_LightningFlash</eventClass>
            </li>
            <li>
                <averageInterval>600</averageInterval>
                <eventClass>WeatherEvent_LightningStrike</eventClass>
            </li>
        </eventMakers>
        <commonalityRainfallFactor>
            <points>
                <li>(0, 0)</li>
                <li>(1300, 1)</li>
                <li>(4000, 3.0)</li>
            </points>
        </commonalityRainfallFactor>
        <!-- Colors are Overcast -->
        <skyColorsDay>
            <sky>(0.8,0.8,0.8)</sky>
            <shadow>(0.92,0.92,0.92)</shadow>
            <overlay>(0.7,0.7,0.7)</overlay>
            <saturation>0.9</saturation>
        </skyColorsDay>
        <skyColorsDusk>
            <sky>(1,1,1)</sky>
            <shadow>(0.92,0.92,0.92)</shadow>
            <overlay>(0.6,0.6,0.6)</overlay>
            <saturation>0.9</saturation>
        </skyColorsDusk>
        <skyColorsNightEdge>
            <sky>(0.35,0.40,0.45)</sky>
            <shadow>(0.92,0.92,0.92)</shadow>
            <overlay>(0.5,0.5,0.5)</overlay>
            <saturation>0.9</saturation>
        </skyColorsNightEdge>
            <skyColorsNightMid>
            <sky>(0.35,0.40,0.45)</sky>
            <shadow>(0.92,0.92,0.92)</shadow>
            <overlay>(0.5,0.5,0.5)</overlay>
            <saturation>0.9</saturation>
        </skyColorsNightMid>
        
    </WeatherDef>
</Defs>
